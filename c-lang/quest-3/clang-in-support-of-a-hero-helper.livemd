```elixir
city2index =
  """
  "Esbjerg",
  "Helsingør",
  "Herning",
  "Horsens",
  "Kolding",
  "København",
  "Næstved",
  "Odense",
  "Randers",
  "Roskilde",
  "Silkeborg",
  "Vejle",
  "Viborg",
  "Aalborg",
  "Århus",
  """
  |> String.split("\n")
  |> Enum.map(fn name -> name |> String.trim(",") |> String.trim("\"") end)
  |> Enum.filter(fn name -> name != "" end)
  |> Enum.with_index()
  |> Map.new()
```

